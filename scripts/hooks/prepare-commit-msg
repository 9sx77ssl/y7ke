#!/usr/bin/env bash
# Historical: this hook used to prepend CHANGELOG.md entries with the
# bumped version. That ran AFTER the index snapshot, so the entry landed
# in the NEXT commit and every GitHub release tag rendered without notes.
# The entry is now written from pre-commit instead; this hook is a no-op
# kept only because scripts/hooks/install or `git config core.hooksPath`
# may still reference it. Safe to delete in a follow-up.
exit 0
