#!/usr/bin/env bash
# Auto-bump patch version on every commit. Updates Cargo.toml,
# src-tauri/tauri.conf.json, ui/package.json, and prepends a CHANGELOG.md
# entry with the commit subject.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Skip if amending or rebasing — version already in flight.
if [ -n "${GIT_INDEX_FILE:-}" ] && [ -f .git/MERGE_MSG ]; then exit 0; fi
if [ -f .git/rebase-apply/applying ] || [ -d .git/rebase-merge ]; then exit 0; fi

current=$(grep '^version' Cargo.toml | head -1 | sed -E 's/.*"([^"]+)".*/\1/')
IFS='.' read -r maj min pat <<< "$current"
next="$maj.$min.$((pat + 1))"

# Workspace version
sed -i -E "0,/^version[[:space:]]*=[[:space:]]*\"$current\"/ s//version      = \"$next\"/" Cargo.toml
# Tauri config
sed -i -E "s/\"version\": \"$current\"/\"version\": \"$next\"/" src-tauri/tauri.conf.json
# UI package
sed -i -E "s/\"version\": \"$current\"/\"version\": \"$next\"/" ui/package.json

git add Cargo.toml src-tauri/tauri.conf.json ui/package.json

# Prepend a CHANGELOG entry now, while we're still in pre-commit — the
# index is re-snapshotted from here. prepare-commit-msg runs after the
# snapshot, so anything staged there ends up in the *next* commit instead
# of this one (which is how GitHub release notes ended up empty for
# every tag — the entry always arrived one commit late).
today=$(date +%Y-%m-%d)
subject=""
if [ -f .git/COMMIT_EDITMSG ]; then
  subject=$(grep -m1 -vE '^(#|$)' .git/COMMIT_EDITMSG || true)
fi
[ -z "$subject" ] && subject="(no commit subject available)"

entry="## [$next] — $today

- $subject
"

if [ -f CHANGELOG.md ]; then
  tmp=$(mktemp)
  awk -v entry="$entry" '
    BEGIN { inserted = 0 }
    /^## \[/ && !inserted { print entry; inserted = 1 }
    { print }
    END { if (!inserted) print entry }
  ' CHANGELOG.md > "$tmp"
  mv "$tmp" CHANGELOG.md
else
  printf "# Changelog\n\n%s" "$entry" > CHANGELOG.md
fi
git add CHANGELOG.md

echo "[pre-commit] $current → $next"
