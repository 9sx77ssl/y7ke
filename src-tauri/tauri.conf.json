{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Y7KE",
  "version": "0.1.0",
  "identifier": "com.y7ke.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --dir ui dev",
    "beforeBuildCommand": "pnpm --dir ui build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Y7KE",
        "width": 960,
        "height": 720,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
